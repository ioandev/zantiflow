# zantiflow deployment env — copy to `.env` and fill in. NEVER commit `.env` (ADR-0018 §4).
# Placeholders only below. Generate secrets with e.g. `openssl rand -base64 48`.

# --- Database ---
DB_PASSWORD=CHANGE_ME
DB_ROOT_PASSWORD=CHANGE_ME
# Backend connection string — user/password must match DB_PASSWORD above; host = the `mariadb` service.
DATABASE_URL=mysql://zantiflow:CHANGE_ME@mariadb:3306/zantiflow

# --- Backend session/state signing (HMAC) ---
# ≥32 bytes random. Rotate with overlap by listing old,new comma-separated (ADR-0018 §4).
TOKEN_SECRET=CHANGE_ME
COOKIE_SECURE=1
SESSION_TTL_DAYS=14
NOTIFICATION_RETENTION_HOURS=6

# --- Backend runtime / web tier ---
NODE_ENV=production
PORT=4000
LOG_LEVEL=info
# Public web origin allowed to call the API with credentials (CORS lock; ADR-0018 §8).
WEB_ORIGIN=https://zantiflow.example
# Express `trust proxy` — the hops in front of the backend (Caddy). e.g. loopback, 1, or a CIDR.
TRUST_PROXY=loopback
# The web container proxies /api/v1 → backend on the compose network.
BACKEND_URL=http://backend:4000

# --- Google OAuth (register your OWN app; ADR-0004) ---
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://zantiflow.example/api/v1/auth/google/callback

# --- Self-host owner sign-in (OPTIONAL; self-host only — leave UNSET on the public deployment; ADR-0035) ---
# A single long secret that signs you in as the one owner when you DON'T want to register a Google app.
# Set it (and leave GOOGLE_* unset) to sign in at /login with just this secret. ≥32 chars, MUST differ
# from TOKEN_SECRET, and requires HTTPS (it's sent in a request body). Generate: openssl rand -base64 48.
# SELF_HOST_SECRET=

# --- Web Push (VAPID; ADR-0006). Generate a keypair with `npx web-push generate-vapid-keys`. ---
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME

# --- Bots (optional; only if you enable them in compose; ADR-0007/0010) ---
BOT_SERVICE_SECRET=CHANGE_ME
# DISCORD_BOT_TOKEN=
# DISCORD_APP_ID=
# DISCORD_GUILD_ID=
# TELEGRAM_BOT_TOKEN=
# BACKEND_WS_URL=wss://backend:4000/internal/bots
