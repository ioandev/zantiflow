# zantiflow web dashboard (ADR-0021). Next.js standalone output → slim non-root runtime. Build CONTEXT
# is the repo root:  docker build -f apps/web/Dockerfile -t zantiflow/web .
# syntax=docker/dockerfile:1
FROM node:22-slim AS build
WORKDIR /repo
RUN corepack enable
COPY . .
RUN pnpm install --frozen-lockfile
# Build identity (set at build time; see docker-publish.yml). Declared after `install` so a changing
# GIT_SHA doesn't bust the dependency layer; `next build` inlines these into the bundle.
ARG APP_VERSION=dev
ARG GIT_SHA=unknown
# `next build` bakes the /api/v1 → backend rewrite destination into routes-manifest.json at BUILD time
# (Next evaluates next.config `rewrites()` during build, not at server start), so BACKEND_URL must be
# set HERE — a runtime env in docker-compose is read too late and has no effect. Default to the compose
# service name used by deploy/docker-compose.example.yml; override with --build-arg for other topologies.
ARG BACKEND_URL=http://backend:4000
ENV APP_VERSION=${APP_VERSION} GIT_SHA=${GIT_SHA} BACKEND_URL=${BACKEND_URL}
RUN pnpm --filter @zantiflow/web build

FROM node:22-slim AS runtime
WORKDIR /app
# Fixed UID/GID 5320 — matches the host deploy perms for zantiflow-web (server-2-perms).
RUN groupadd -r -g 5320 app && useradd -r -u 5320 -g app -d /app app
# `output: 'standalone'` emits a minimal server + node_modules under .next/standalone (monorepo layout).
COPY --from=build --chown=app:app /repo/apps/web/.next/standalone ./
COPY --from=build --chown=app:app /repo/apps/web/.next/static ./apps/web/.next/static
COPY --from=build --chown=app:app /repo/apps/web/public ./apps/web/public
# Third-party license compliance: ship our own license/notice + the web app's third-party manifest
# (generated by `just license`, committed to the repo). Must exist at build time.
COPY --chown=app:app LICENSE NOTICE apps/web/LICENSES ./
# Carry the build identity into the runtime env too (parity with the other images / `docker inspect`).
ARG APP_VERSION=dev
ARG GIT_SHA=unknown
USER app
ENV NODE_ENV=production PORT=3000 HOSTNAME=0.0.0.0 APP_VERSION=${APP_VERSION} GIT_SHA=${GIT_SHA}
EXPOSE 3000
HEALTHCHECK --interval=15s --timeout=5s --retries=5 \
  CMD node -e "fetch('http://localhost:3000/healthz').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"
CMD ["node", "apps/web/server.js"]
