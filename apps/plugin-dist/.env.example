# Local dev env for `pnpm dev` (loaded via --env-file-if-exists). Copy to `.env` and adjust.
# Every value below has a sensible default (see src/config/index.ts) — nothing is required.

NODE_ENV=development
PORT=4500
LOG_LEVEL=debug

# The GitHub repo whose Releases publish zantiflow.wasm (ADR-0022), as "owner/name".
GITHUB_REPO=ioandev/zantiflow

# Optional read-only PAT. Raises the API rate limit 60/hr -> 5000/hr. The wasm itself is always
# downloaded over its public browser_download_url (no auth) — this token only signs the list call.
# GITHUB_TOKEN=

# The release asset to mirror + the path we serve it under.
WASM_ASSET_NAME=zantiflow.wasm

# How often to re-check GitHub for a higher-SemVer release (ms; min 15000).
POLL_INTERVAL_MS=300000

# `Cache-Control: public, max-age=` sent with the served asset (seconds).
CACHE_MAX_AGE_SECONDS=300

# Per-request timeout for GitHub calls (ms).
REQUEST_TIMEOUT_MS=20000

# Consider prerelease tags when picking "latest" (default: full releases only).
ALLOW_PRERELEASE=false
