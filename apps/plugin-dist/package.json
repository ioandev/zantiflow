{
  "name": "@zantiflow/plugin-dist",
  "version": "0.1.0",
  "private": true,
  "description": "zantiflow plugin distribution origin — mirrors the highest-SemVer zantiflow.wasm GitHub Release and serves it at /zantiflow.wasm.",
  "license": "Apache-2.0",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
