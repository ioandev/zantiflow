# zantiflow Telegram bot env — copy to `.env` and fill in. `.env` is gitignored.
# Loaded by python-dotenv in bot.py; real process env / compose env_file still win. (ADR-0007/0010)

# BotFather token (https://t.me/BotFather → /newbot). Required.
TELEGRAM_BOT_TOKEN=

# Shared secret for the bot↔backend WS `hello` (ADR-0007). MUST match the backend's BOT_SERVICE_SECRET.
BOT_SERVICE_SECRET=

# Backend WS hub. Compose default: ws://backend:4000/internal/bots. Local dev: ws://127.0.0.1:4000/internal/bots.
BACKEND_WS_URL=ws://127.0.0.1:4000/internal/bots

# Public website shown in the bot's /help and onboarding (default https://zantiflow.com; self-hosters set their own).
WEBSITE_URL=https://zantiflow.com
