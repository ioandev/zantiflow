# zantiflow Telegram bot (ADR-0021). Build CONTEXT is the repo root (needs the shared protocol package):
#   docker build -f apps/telegram-bot/Dockerfile -t zantiflow/telegram-bot .
# syntax=docker/dockerfile:1
FROM python:3.12-slim AS runtime
WORKDIR /app
# Fixed UID/GID 5325 — matches the host deploy perms for zantiflow-telegram-bot (server-2-perms).
RUN groupadd -r -g 5325 app && useradd -r -u 5325 -g app -d /app app
COPY packages/notify-protocol /packages/notify-protocol
COPY apps/telegram-bot /app
# Third-party license compliance: our own license/notice + the monorepo third-party manifest
# (generated by `just license`, committed to the repo). Must exist at build time.
COPY LICENSE NOTICE LICENSES /app/
RUN pip install --no-cache-dir /packages/notify-protocol "aiogram>=3.13" "python-dotenv>=1.0"
# Build identity (set at build time; see docker-publish.yml). Logged at startup. Declared after the
# pip layer so a changing GIT_SHA doesn't bust it.
ARG APP_VERSION=dev
ARG GIT_SHA=unknown
USER app
ENV PYTHONUNBUFFERED=1 APP_VERSION=${APP_VERSION} GIT_SHA=${GIT_SHA}
CMD ["python", "bot.py"]
