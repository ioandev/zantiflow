# zantiflow backend (ADR-0021). Multi-stage, non-root, pinned base. Build CONTEXT is the repo root
# (the backend depends on workspace packages), so build with:
#   docker build -f apps/backend/Dockerfile -t zantiflow/backend .
# syntax=docker/dockerfile:1
FROM node:22-slim AS build
WORKDIR /repo
# Prisma needs OpenSSL to pick its engine.
RUN apt-get update && apt-get install -y --no-install-recommends openssl && rm -rf /var/lib/apt/lists/*
RUN corepack enable
COPY . .
RUN pnpm install --frozen-lockfile
# Build the backend + the workspace packages it depends on.
RUN pnpm --filter @zantiflow/backend... build
# Produce a self-contained production deployment of just the backend (workspace deps injected).
RUN pnpm --filter=@zantiflow/backend --prod --legacy deploy /prod
# Generate the Prisma client inside the deployment (schema + migrations travel with it).
RUN cd /prod && node_modules/.bin/prisma generate

FROM node:22-slim AS runtime
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends openssl && rm -rf /var/lib/apt/lists/*
# Fixed UID/GID 5321 — matches the host deploy perms for zantiflow-backend (server-2-perms).
RUN groupadd -r -g 5321 app && useradd -r -u 5321 -g app -d /app app
COPY --from=build --chown=app:app /prod /app
COPY --chown=app:app apps/backend/docker-entrypoint.sh /app/docker-entrypoint.sh
RUN chmod +x /app/docker-entrypoint.sh
# Third-party license compliance: our own license/notice + the monorepo third-party manifest
# (generated by `just license`, committed to the repo). Must exist at build time.
COPY --chown=app:app LICENSE NOTICE LICENSES ./
# Build identity (set at build time; see docker-publish.yml). Read at runtime for the startup log +
# /healthz. Declared here in the runtime stage so a changing GIT_SHA never busts the layers above.
ARG APP_VERSION=dev
ARG GIT_SHA=unknown
USER app
ENV NODE_ENV=production PORT=4000 APP_VERSION=${APP_VERSION} GIT_SHA=${GIT_SHA}
EXPOSE 4000
HEALTHCHECK --interval=15s --timeout=5s --retries=5 \
  CMD node -e "fetch('http://localhost:4000/healthz').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"
# Entrypoint applies pending migrations, then starts the server.
ENTRYPOINT ["/app/docker-entrypoint.sh"]
