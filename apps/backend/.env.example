# Local dev env for `pnpm dev` (loaded via --env-file-if-exists). Copy to `.env` and adjust.
# Deploy/compose config lives in ../../deploy/.env.example — this file is for running the
# backend directly on your machine. Only DATABASE_URL and TOKEN_SECRET are required; the rest
# have sensible defaults (see src/config/index.ts).

NODE_ENV=development
PORT=4000

# MariaDB connection (Prisma). Matches the dev DB in docker-compose.dev.yml (host port 3308).
# Bring it up with `pnpm db:up`. 3306/3307 are already taken on this machine, hence 3308.
DATABASE_URL=mysql://zantiflow:zantiflow@127.0.0.1:3308/zantiflow

# HMAC key for ztf_session cookies + OAuth state. Must be >=32 chars. Dev-only value below.
TOKEN_SECRET=dev-only-insecure-secret-change-me-32chars

# The web origin allowed to call the API with credentials (CORS).
WEB_ORIGIN=http://localhost:3000

LOG_LEVEL=debug

# --- Optional integrations (leave unset to run without them) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback
# Self-host owner sign-in (ADR-0035): set a single >=32-char secret to sign in as the sole owner at
# /login WITHOUT registering a Google app (leave GOOGLE_* unset). Must differ from TOKEN_SECRET.
# Generate: openssl rand -base64 48.
# SELF_HOST_SECRET=
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# Shared secret authenticating the bot↔backend WS hello (ADR-0007). Same value on the bots.
BOT_SERVICE_SECRET=changeme
